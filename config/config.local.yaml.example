# 本地开发覆盖配置模板
# 复制此文件为 config.local.yaml，填入本地连接信息
# config.local.yaml 已加入 .gitignore，不会提交到 git

server:
  mode: debug

log:
  level: debug
  format: console

db:
  host: localhost
  port: 3306
  name: blog_dev
  user: root
  password: your_local_db_password

redis:
  addr: localhost:6379
  password: ""

jwt:
  secret: "local-dev-secret-change-before-prod"

garage:
  endpoint: "https://garage-s3-api.example.com"
  region: "garage"
  bucket: "blog"
  accessKeyID: "your_garage_access_key_id"
  secretAccessKey: "your_garage_secret_access_key"
  cdn: true

cdn:
  host: "https://blog-oss.example.com"
  secret: "your_cdn_sign_secret"
  signQueryName: "a"
  timestampQueryName: "b"

# 迁移工具专用：源库连接信息（只读，生产数据，不要提交到 git）
migrate:
  src_dsn: "databaseName:pwd_@tcp(ip:port)/blog?charset=utf8mb4&parseTime=True&loc=Local"

email:
  host: smtp.xxx.com
  port: 465
  from: xxxxx@xx.com
  password: ""

oauth:
  providers:
    github:
      enabled: true
      client_id: "your_github_client_id"
      client_secret: "your_github_client_secret"
      redirect_uri: "http://localhost:8080/oauth/github/callback"
    gitee:
      enabled: false
      client_id: "your_gitee_client_id"
      client_secret: "your_gitee_client_secret"
      redirect_uri: "http://localhost:8080/oauth/gitee/callback"
    qq:
      enabled: false
      client_id: "your_qq_client_id"
      client_secret: "your_qq_client_secret"
      redirect_uri: "http://localhost:8080/oauth/qq/callback"
    weibo:
      enabled: false
      client_id: "your_weibo_client_id"
      client_secret: "your_weibo_client_secret"
      redirect_uri: "http://localhost:8080/oauth/weibo/callback"
    baidu:
      enabled: false
      client_id: "your_baidu_client_id"
      client_secret: "your_baidu_client_secret"
      redirect_uri: "http://localhost:8080/oauth/baidu/callback"
