# Docker 敏感变量模板
# 复制为 .env 并填写真实值（.env 已加入 .gitignore，不会提交到 git）

# MySQL（生产环境通常由宝塔或独立实例提供）
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=blog_prod
DB_USER=blog
DB_PASSWORD=change_me_db_password

# Redis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=
REDIS_PORT=6379

# JWT 签名密钥（生产环境务必使用长随机字符串）
JWT_SECRET=change_me_jwt_secret_use_long_random_string

# Garage 对象存储
STORAGE_ENDPOINT=http://your-garage-server:3900
STORAGE_BUCKET=blog
STORAGE_REGION=garage
STORAGE_ACCESS_KEY=your_access_key
STORAGE_SECRET_KEY=your_secret_key
STORAGE_CDN=false

CDN_HOST=http://your-cdn-domain
CDN_SECRET=your_cdn_secret
CDN_SIGN_QUERY_NAME=a
CDN_TIMESTAMP_QUERY_NAME=b

# 服务端口（可选，默认 8080）
SERVER_PORT=8080
