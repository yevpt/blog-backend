# Docker 敏感变量模板
# 复制为 .env 并填写真实值（.env 已加入 .gitignore，不会提交到 git）

# MySQL
MYSQL_ROOT_PASSWORD=change_me_root_password
MYSQL_DATABASE=blog_prod
MYSQL_USER=blog
MYSQL_PASSWORD=change_me_db_password
MYSQL_PORT=3306

# Redis
REDIS_PASSWORD=
REDIS_PORT=6379

# JWT 签名密钥（生产环境务必使用长随机字符串）
JWT_SECRET=change_me_jwt_secret_use_long_random_string

# Garage 对象存储
STORAGE_ENDPOINT=http://your-garage-server:3900
STORAGE_ACCESS_KEY=your_access_key
STORAGE_SECRET_KEY=your_secret_key

# 服务端口（可选，默认 8080）
SERVER_PORT=8080
